# Dokploy admin panel — Tailscale-only access
# Managed by Ansible — do not edit manually
http:
  routers:
    dokploy-router-app:
      rule: "Host(`dokploy.docker.localhost`) && PathPrefix(`/`)"
      service: dokploy-service-app
      entryPoints:
        - web
      middlewares:
        - redirect-to-https
    dokploy-router-app-secure:
      rule: "Host(`{{ dokploy_domain }}`)"
      service: dokploy-service-app
      entryPoints:
        - websecure
      tls:
        certResolver: letsencrypt
      middlewares:
        - tailscale-only
  services:
    dokploy-service-app:
      loadBalancer:
        servers:
          - url: http://dokploy:3000
        passHostHeader: true
