services:
  {{ pihole_container_name }}:
    container_name: {{ pihole_container_name }}
    image: {{ pihole_image }}
    restart: unless-stopped
    network_mode: host
    labels:
      - "traefik.enable=false"

    deploy:
      resources:
        limits:
          memory: 256m
        reservations:
          memory: 128m
    environment:
      TZ: {{ homelab_timezone | default('UTC') }}
      FTLCONF_webserver_api_password: {{ pihole_password }}
      # Pi-hole v6+ web server port configuration
      FTLCONF_webserver_port: "{{ pihole_web_port }}"
      # Upstream DNS — prevents dnsmasq from using local interface as upstream
      FTLCONF_dns_upstreams: "{{ pihole_upstream_dns | join(';') }}"
      # Enable reading /etc/dnsmasq.d/ configs (required for local DNS in v6+)
      FTLCONF_misc_etc_dnsmasq_d: "true"
    volumes:
      - {{ pihole_data_dir }}/etc-pihole:/etc/pihole
      - {{ pihole_data_dir }}/etc-dnsmasq.d:/etc/dnsmasq.d
    cap_add:
      - NET_ADMIN
    healthcheck:
      test: ["CMD", "dig", "+short", "@127.0.0.1", "pi.hole"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
