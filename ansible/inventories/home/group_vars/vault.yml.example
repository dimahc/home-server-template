---
# Vault-encrypted secrets for home environment
#
# This file should be encrypted with ansible-vault:
#   ansible-vault encrypt ansible/inventories/home/group_vars/vault.yml
#
# To edit:
#   ansible-vault edit ansible/inventories/home/group_vars/vault.yml
#
# To run playbooks with vault:
#   ansible-playbook -i inventories/home/hosts.yml playbooks/site.yml --ask-vault-pass
#   OR use a vault password file:
#   ansible-playbook -i inventories/home/hosts.yml playbooks/site.yml --vault-password-file ~/.vault_pass

# Pi-hole admin password
vault_pihole_password: "CHANGE_ME_THEN_ENCRYPT"

# Cloudflare Tunnel token (from Zero Trust dashboard)
vault_cloudflare_tunnel_token: "CHANGE_ME_THEN_ENCRYPT"

# Tailscale auth key (from https://login.tailscale.com/admin/settings/keys)
# Use a reusable key. Recommended: reusable + ephemeral for servers.
vault_tailscale_auth_key: "tskey-auth-CHANGE_ME_THEN_ENCRYPT"

# Alexa Skill web UI basic auth (optional but recommended)
vault_alexa_skill_app_username: "CHANGE_ME_THEN_ENCRYPT"
vault_alexa_skill_app_password: "CHANGE_ME_THEN_ENCRYPT"

# HA API token
vault_ha_api_token: "CHANGE_ME_THEN_ENCRYPT"
